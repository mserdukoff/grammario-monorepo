{
  "name": "grammario-video",
  "version": "1.0.0",
  "description": "Remotion demo video for Grammario",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts LandscapeVideo out/grammario-youtube.mp4",
    "build:portrait": "remotion render src/index.ts PortraitVideo out/grammario-shorts.mp4",
    "build:all": "npm run build && npm run build:portrait"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.232",
    "@remotion/player": "^4.0.232",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.232"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
