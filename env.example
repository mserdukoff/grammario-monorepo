# ===========================================
# Grammario Environment Configuration
# ===========================================
# This project has two services:
# 1. Next.js Frontend - handles auth, user management, billing
# 2. Python Backend - handles NLP/linguistic analysis only
#
# Copy relevant sections to:
# - frontend/.env.local (for Next.js)
# - backend/.env (for Python)


# ===========================================
# FRONTEND (Next.js) - frontend/.env.local
# ===========================================

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Only needed for webhooks

# NLP Backend URL (Required)
API_URL=http://127.0.0.1:8000

# Stripe (Optional - for Pro subscriptions)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID=price_xxx


# ===========================================
# BACKEND (Python NLP Engine) - backend/.env
# ===========================================

# LLM for pedagogical data (Required)
# Get a free key at https://openrouter.ai
OPENROUTER_KEY=sk-or-v1-xxx

# Fallback LLM (Optional)
# OPENAI_API_KEY=sk-xxx

# Model override (Optional)
# LLM_MODEL=google/gemini-2.0-flash-exp:free

# Debug mode (Optional - enables /docs endpoint)
DEBUG=true

# CORS origins (Required - should include your Next.js URL)
CORS_ORIGINS=http://localhost:3000

# Stanza models directory (Optional)
# STANZA_RESOURCES_DIR=/path/to/stanza_resources
