# ===========================================
# Grammario Backend Environment Configuration
# ===========================================
# Copy this file to backend/.env

# ===== REQUIRED: SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings
# Get JWT Secret from: Supabase Dashboard → Settings → API → JWT Secret

# ===== REQUIRED: LLM =====
# Get a free key at https://openrouter.ai
OPENROUTER_KEY=sk-or-v1-xxx

# ===== OPTIONAL =====
# Fallback LLM (if OpenRouter fails)
# OPENAI_API_KEY=sk-xxx

# Model override
# LLM_MODEL=google/gemini-2.0-flash-exp:free

# Debug mode (enables /docs endpoint)
DEBUG=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ===== STRIPE (Coming Soon) =====
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID=price_xxx
